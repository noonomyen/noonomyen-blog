{
  "name": "noonomyen-blog",
  "private": true,
  "description": "fuwari blog framework customized for noonomyen blog",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "bunx --bun astro dev",
    "start": "bun ./dist/server.js",
    "check": "bunx --bun astro check",
    "build:frontend-dev": "NODE_ENV=development bun run scripts/generate-favicon.js && NODE_ENV=development bunx --bun astro build && bun run scripts/rearrange-dist.ts && pagefind --site dist/content-static",
		"build:frontend-prod": "NODE_ENV=production bun run scripts/generate-favicon.js && NODE_ENV=production bunx --bun astro build && bun run scripts/rearrange-dist.ts && bun run scripts/purge-astro-pngs.ts && pagefind --site dist/content-static",
    "build:backend-dev": "bun build --target=bun ./src/server/index.ts --outfile ./dist/server.js",
    "build:backend-prod": " bun build --production --target=bun ./src/server/index.ts --outfile ./dist/server.js",
    "build:dev": "bun run build:frontend-dev && bun run build:backend-dev",
    "build:prod": "bun run build:frontend-prod && bun run build:backend-prod",
    "build": "bun run build:prod",
    "preview": "bunx --bun astro preview",
    "astro": "bunx --bun astro",
    "type-check": "tsc --noEmit",
    "new-post": "bun run scripts/new-post.js",
    "format": "biome format --write ./src",
    "lint": "biome check --write ./src",
    "test": "bun test --concurrency 1 test/*.test.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/node": "^10.1.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "7.2.5",
    "@astrojs/tailwind": "^6.0.2",
    "@elysiajs/static": "^1.4.10",
    "@expressive-code/core": "^0.42.0",
    "@expressive-code/plugin-collapsible-sections": "^0.42.0",
    "@expressive-code/plugin-line-numbers": "^0.42.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-regular": "^1.2.4",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@iconify-json/material-symbols": "^1.2.75",
    "@iconify/svelte": "^4.2.0",
    "@swup/astro": "^1.8.0",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^6.4.2",
    "astro-expressive-code": "^0.42.0",
    "astro-icon": "^1.1.5",
    "elysia": "^1.4.28",
    "hastscript": "^9.0.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "mdast-util-to-string": "^4.0.0",
    "overlayscrollbars": "^2.16.0",
    "pagefind": "^1.5.2",
    "photoswipe": "^5.4.4",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-components": "^0.3.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^3.0.1",
    "remark-directive-rehype": "^0.4.2",
    "remark-github-admonitions-to-directives": "^1.0.5",
    "remark-math": "^6.0.0",
    "remark-sectionize": "^2.1.0",
    "sanitize-html": "^2.17.4",
    "sharp": "^0.34.5",
    "stylus": "^0.64.0",
    "svelte": "^5.56.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.9",
    "@biomejs/biome": "2.4.16",
    "@rollup/plugin-yaml": "^4.1.2",
    "@types/bun": "^1.3.14",
    "@types/hast": "^3.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/mdast": "^4.0.4",
    "@types/sanitize-html": "^2.16.1",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^13.0.2"
  }
}

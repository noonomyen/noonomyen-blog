---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";
---

<MainGridLayout title="404 Not Found">
    <div class="card-base flex flex-col justify-center items-center py-20 px-6 text-center rounded-[var(--radius-large)] overflow-hidden relative min-h-[450px]">
        <div class="flex items-center justify-center bg-[var(--primary-fade)] text-[var(--primary)] rounded-full w-24 h-24 mb-6">
            <Icon name="material-symbols:error-outline-rounded" class="text-6xl" />
        </div>
        <h1 class="text-5xl md:text-6xl font-black text-90 mb-2 tracking-tight">404</h1>
        <h2 class="text-2xl md:text-3xl font-bold text-75 mb-4">Page Not Found</h2>
        <p class="text-base text-50 max-w-sm">
            The page you are looking for does not exist or has been moved.
        </p>
    </div>
</MainGridLayout>
